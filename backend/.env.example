# Copy to .env and fill in real values. NEVER commit .env.
# In prod on EC2, the bootstrap script writes this file from SSM Parameter Store.

NODE_ENV=production
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/resumeright?retryWrites=true&w=majority
DB_NAME=resumeright

# Admin bootstrap key (used by POST /admin/login to issue a JWT)
ADMIN_KEY=change-me-to-a-long-random-string

# JWT signing secret (MUST be >= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-at-least-thirty-two-characters-long
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# AWS (S3 uploads). Leave S3_BUCKET_UPLOADS blank to fall back to local disk in dev.
AWS_REGION=ap-south-1
S3_BUCKET_UPLOADS=

# Comma-separated origin allowlist. Use "*" only in dev.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate limiting (general API)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
